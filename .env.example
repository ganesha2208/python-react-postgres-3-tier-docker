# Copy this file to .env on the EC2 host and fill in values.
# Used by docker-compose.prod.yml via variable substitution.

# AWS ECR registry, e.g. 563332534764.dkr.ecr.ap-south-1.amazonaws.com
ECR_REGISTRY=

# Image tag to deploy. CI sets this to the short commit SHA on each deploy.
TAG=latest

# Public site address used by Caddy.
# - For HTTP-only (during early setup): :80
# - For HTTPS once you have a domain:   yourname.duckdns.org
SITE_ADDRESS=:80

# Postgres credentials (override defaults if you like)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=itemsdb
